PORT=5000
MONGO_URI=mongodb://localhost:27017/expense-tracker
JWT_SECRET=your_jwt_secret_here

# =============================================================================
# EMAIL — required for registration / password / delete verification codes
# Configure ONE option below, then restart: npm run dev
# =============================================================================

# --- Option A: Resend (easiest) ---
# 1. Sign up at https://resend.com
# 2. Create an API key at https://resend.com/api-keys
# 3. On the free plan you can send to your own email using the default sender:
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM=Hisaab <onboarding@resend.dev>

# --- Option B: Gmail SMTP ---
# 1. Turn on 2-Step Verification for your Google account
# 2. Create an App Password: https://myaccount.google.com/apppasswords
# 3. Use that 16-character password as SMTP_PASS (not your normal Gmail password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your.email@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM=Hisaab <your.email@gmail.com>
